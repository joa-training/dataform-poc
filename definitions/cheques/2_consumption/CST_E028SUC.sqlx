config {
  type: "incremental",
  schema: "cst_banking",
  name: "E028SUC",
  tags: ["E028SUC_cst", "cst"],
  bigquery: {
    partitionBy: "FECHA_PROCESO"
  }
}

SELECT *
FROM `${dataform.projectConfig.defaultDatabase}.std_banking.TODO_maestro_table`
WHERE CAST(FECHA_PROCESO AS DATE) = DATE('${dataform.projectConfig.vars.process_date}')
