
config {
    type: "incremental",
    schema: constants.DEST_STD,
    name: "STD_00250_IDX",
    tags: ["00250_IDX_std", "std"],
    
  uniqueKey: ["SPONSOR"],
    bigquery: {
        partitionBy: "FECHA_PROCESO"
     },
    
    assertions: {
        
  uniqueKey: ["SPONSOR"],
    }
    
}
SELECT
    CAST(load_date AS DATE) AS FECHA_PROCESO,
    RUT_CRUCE,
		SAFE_CAST(COD_PROD AS NUMERIC) AS COD_PROD,
		SAFE_CAST(NUM_ID_PRO AS NUMERIC) AS NUM_ID_PRO,
		SAFE_CAST(STATUS_PROD AS NUMERIC) AS STATUS_PROD,
		TIPO_CUENTA,
		SAFE_CAST(SUCURSAL AS NUMERIC) AS SUCURSAL,
		SAFE_CAST(TIPO_MONEDA AS NUMERIC) AS TIPO_MONEDA,
		TIPO_TASA,
		SAFE_CAST(TASA AS NUMERIC) AS TASA,
		SAFE_CAST(REAJUSTABILIDAD AS NUMERIC) AS REAJUSTABILIDAD,
		SAFE_CAST(FECHA_EMI AS NUMERIC) AS FECHA_EMI,
		SAFE_CAST(FECHA_VCTO AS NUMERIC) AS FECHA_VCTO,
		SAFE_CAST(MONTO_VIGENTE AS NUMERIC) AS MONTO_VIGENTE,
		REFERENCIA_CLI,
		NOMBRE_EJE,
		EMAIL,
		TIPO_CUENTA_EMP,
		RUT_PATRO,
		SAFE_CAST(PROCESADO AS NUMERIC) AS PROCESADO,
		TITULAR_CTA
FROM `${dataform.projectConfig.defaultDatabase}.raw_banking.raw_00250_IDX_daily`
WHERE load_date = DATE('${dataform.projectConfig.vars.process_date}')
