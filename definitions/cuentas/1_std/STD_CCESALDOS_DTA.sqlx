		SAFE_CAST(SCD_15 AS NUMERIC) AS SCD_15,
		SAFE_CAST(SCD_16 AS NUMERIC) AS SCD_16,
		SAFE_CAST(SCD_17 AS NUMERIC) AS SCD_17,
		SAFE_CAST(SCD_18 AS NUMERIC) AS SCD_18,
		SAFE_CAST(SCD_19 AS NUMERIC) AS SCD_19,
