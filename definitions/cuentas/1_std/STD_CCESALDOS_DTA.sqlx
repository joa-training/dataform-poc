		SAFE_CAST(SDD_12 AS NUMERIC) AS SDD_12,
		SAFE_CAST(SDD_13 AS NUMERIC) AS SDD_13,
		SAFE_CAST(SDD_14 AS NUMERIC) AS SDD_14,
		SAFE_CAST(SDD_15 AS NUMERIC) AS SDD_15,
