
config {
    type: "incremental",
    schema: constants.DEST_STD,
    name: "STD_CCESALDOS_DTA",
    tags: ["CCESALDOS_DTA_std", "std"],
    
    bigquery: {
        partitionBy: "FECHA_PROCESO"
     },
    
}
