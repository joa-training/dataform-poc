		SAFE_CAST(SCD_26 AS NUMERIC) AS SCD_26,
		SAFE_CAST(SCD_27 AS NUMERIC) AS SCD_27,
		SAFE_CAST(SCD_28 AS NUMERIC) AS SCD_28,
		SAFE_CAST(SCD_29 AS NUMERIC) AS SCD_29,
		SAFE_CAST(SCD_30 AS NUMERIC) AS SCD_30,
		SAFE_CAST(SCD_31 AS NUMERIC) AS SCD_31,
		Filler,
		SAFE_CAST(SDD_1 AS NUMERIC) AS SDD_1,
		SAFE_CAST(SDD_2 AS NUMERIC) AS SDD_2,
		SAFE_CAST(SDD_3 AS NUMERIC) AS SDD_3,
		SAFE_CAST(SDD_4 AS NUMERIC) AS SDD_4,
