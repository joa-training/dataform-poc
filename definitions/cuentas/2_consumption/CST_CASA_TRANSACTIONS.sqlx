config {
  type: "incremental",
  schema: "cst_banking",
  name: "CASA_TRANSACTIONS",
  tags: ["CASA_TRANSACTIONS_cst", "cst"],
  bigquery: {
    partitionBy: "FECHA_PROCESO"
  }
}

SELECT *
FROM `${dataform.projectConfig.defaultDatabase}.std_banking.OPF_CASA_TXN`
WHERE CAST(FECHA_PROCESO AS DATE) = DATE('${dataform.projectConfig.vars.process_date}')
