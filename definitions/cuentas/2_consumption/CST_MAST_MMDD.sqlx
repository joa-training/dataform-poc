config {
  type: "incremental",
  schema: "cst_banking",
  name: "MAST_MMDD",
  tags: ["MAST_MMDD_cst", "cst"],
  bigquery: {
    partitionBy: "FECHA_PROCESO"
  }
}

SELECT *
FROM `${dataform.projectConfig.defaultDatabase}.std_banking.OPF_CASA_MAS`
WHERE CAST(FECHA_PROCESO AS DATE) = DATE('${dataform.projectConfig.vars.process_date}')
