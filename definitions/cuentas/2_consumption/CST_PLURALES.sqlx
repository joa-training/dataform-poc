config {
  type: "incremental",
  schema: "cst_banking",
  name: "PLURALES",
  tags: ["PLURALES_cst", "cst"],
  bigquery: {
    partitionBy: "FECHA_PROCESO"
  }
}

SELECT *
FROM `${dataform.projectConfig.defaultDatabase}.std_banking.MAE_CLIENTES`
WHERE CAST(FECHA_PROCESO AS DATE) = DATE('${dataform.projectConfig.vars.process_date}')
