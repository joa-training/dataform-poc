config {
  type: "incremental",
  schema: "cst_banking",
  name: "PLAN_CTAS_CARTERA",
  tags: ["PLAN_CTAS_CARTERA_cst", "cst"],
  bigquery: {
    partitionBy: "FECHA_PROCESO"
  }
}

SELECT *
FROM `${dataform.projectConfig.defaultDatabase}.std_banking.OPF_VALE_VISTA`
WHERE CAST(FECHA_PROCESO AS DATE) = DATE('${dataform.projectConfig.vars.process_date}')
