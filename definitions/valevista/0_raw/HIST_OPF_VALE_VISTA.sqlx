config {
  type: "incremental",
  schema: "dataset",
  name: "HIST_OPF_VALE_VISTA",
  bigquery: {
    partitionBy: "DATE(FEC_INGESTA)",
    clusterBy: ["NUMERO", "FECHA_EMI"]
  }
}

SELECT
  *
FROM ${ref("RAW_OPF_VALE_VISTA")}

${when(incremental(), 
  `WHERE FEC_INGESTA > (SELECT MAX(FEC_INGESTA) FROM ${self()})` 
)}
