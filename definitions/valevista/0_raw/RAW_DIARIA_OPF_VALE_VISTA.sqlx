
config {
  type: "incremental",
  schema: constants.DEST_RAW_DIARIA,
  name: "RAW_DIARIA_OPF_VALE_VISTA",
  bigquery: {
    partitionBy: "DATE(FEC_INGESTA)",
    clusterBy: ["NUMERO", "FECHA_EMI"]
  }
}

SELECT
  *
FROM
`${constants.ORIG_SCHEMA}.RAW_OPF_VALE_VISTA`
WHERE DATE(FEC_INGESTA) = DATE("${constants.FECHA_EJE}")
   
