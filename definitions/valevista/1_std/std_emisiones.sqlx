config {
  type: "table",
  schema: "dataset",
  name: "STD_OPF_VALE_VISTA",
  bigquery: {
    partitionBy: "DATE(FEC_INGESTA)",
    clusterBy: ["NUMERO", "FECHA_EMI"]
  },
  assertions: {
    uniqueKey: ["SUCUR_EMI", "NUMERO"],
    nonNull: ["RUT_BENEFICIA", "VALOR"]
  }
}

SELECT
  *
FROM ${ref("HIST_OPF_VALE_VISTA")}
WHERE DATE(FEC_INGESTA) = "2026-04-07"
